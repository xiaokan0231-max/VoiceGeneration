<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <key>Label</key><string>local.voicegeneration.gateway</string>
  <key>ProgramArguments</key>
  <array>
    <string>/bin/bash</string>
    <string>__PROJECT_ROOT__/scripts/run_gateway.sh</string>
  </array>
  <key>WorkingDirectory</key><string>__PROJECT_ROOT__</string>
  <key>RunAtLoad</key><true/>
  <key>KeepAlive</key><true/>
  <key>ThrottleInterval</key><integer>10</integer>
  <key>ProcessType</key><string>Background</string>
  <key>StandardOutPath</key><string>__PROJECT_ROOT__/cache/_logs/gateway.out.log</string>
  <key>StandardErrorPath</key><string>__PROJECT_ROOT__/cache/_logs/gateway.err.log</string>
</dict>
</plist>
